<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhucCMS Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 12px 20px;
                transition: all 0.2s ease;
                border-left: 4px solid transparent;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: white;
                    border-left-color: #0d6efd;
                }

            .sidebar i {
                margin-right: 10px;
            }

        .admin-top-header {
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            padding: 12px 24px;
            margin-bottom: 20px;
            border-bottom: 1px solid #e9ecef;
        }

        body {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0 position-fixed">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h4 class="text-white mb-0 fw-bold"><i class="bi bi-shield-lock"></i> PhucCMS Admin</h4>
                </div>
                <div class="mt-3">
                    <a href="/Home/Dashboard"><i class="bi bi-speedometer2"></i> Bảng điều khiển</a>
                    <a href="/Home/Index"><i class="bi bi-globe"></i> Xem trang web</a>

                    <hr class="text-secondary mx-3 my-2" />

                    <a href="/Category/Index"><i class="bi bi-grid"></i>Danh mục bài viết</a>
                    <a href="/Post/Index"><i class="bi bi-file-earmark-post"></i> Quản lý Bài viết</a>
                    <a href="/User/Index"><i class="bi bi-people"></i> Quản lý Thành viên</a>

                    <a href="/Banner/Index"><i class="bi bi-images text-warning"></i> Quản lý Banner</a>

                    <div class="px-3 pt-3 pb-1 text-uppercase text-muted small fw-bold border-top border-secondary mt-2">Kinh doanh</div>

                    <a href="/CategoryProduct/Index"><i class="bi bi-tags"></i> Danh mục sản phẩm</a>
                    <a href="/Product/Index"><i class="bi bi-box-seam"></i> Sản phẩm</a>
                    <a href="/Customer/Index"><i class="bi bi-person-lines-fill"></i> Khách hàng</a>
                    <a href="/Order/Index"><i class="bi bi-receipt"></i> Đơn hàng</a>
                    <a href="/OrderDetail/Index"><i class="bi bi-list-check"></i> Đơn hàng chi tiết</a>
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 p-0" style="margin-left: auto; min-height: 100vh;">
                <div class="admin-top-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="m-0 text-secondary fw-bold">@ViewData["Title"]</h5>
                    </div>
                    <div class="d-flex align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="text-end me-3 border-end pe-3">
                                <span class="d-block fw-bold text-dark" style="font-size: 15px;">
                                    Chào, @User.FindFirst("FullName")?.Value
                                </span>
                                <span class="badge bg-success">
                                    <i class="bi bi-person-badge"></i> @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                </span>
                            </div>
                            <a href="/Account/Logout" class="btn btn-outline-danger btn-sm fw-bold px-3">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        }
                    </div>
                </div>

                <div class="px-4 pb-4">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>