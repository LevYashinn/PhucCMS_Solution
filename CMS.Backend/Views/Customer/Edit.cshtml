@model CMS.Data.Entities.Customer
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> SỬA THÔNG TIN KHÁCH HÀNG</h4>
        </div>
        <div class="card-body p-4">
            <form action="/Customer/Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-bold">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                    <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                </div>

                <div class="d-flex justify-content-between border-top pt-3">
                    <a href="/Customer/Index" class="btn btn-outline-secondary">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning fw-bold px-4 shadow-sm text-dark">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>