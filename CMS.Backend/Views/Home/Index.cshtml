@model IEnumerable<CMS.Data.Entities.Post>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang chủ - PhucCMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-danger shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">PhucCMS</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link active" href="/">Trang chủ</a>
                <a class="nav-link" href="/Post/Index">Vào trang Admin</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h2 class="text-center mb-4 text-danger fw-bold">TIN TỨC MỚI NHẤT</h2>
        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm h-100 border-0">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/600x400?text=No+Image" : item.ImageUrl)" class="card-img-top" alt="Thumbnail" style="height: 220px; object-fit: cover;">
                            <div class="card-body d-flex flex-column">
                                <span class="badge bg-primary mb-2 align-self-start">@item.Category?.Name</span>
                                <h5 class="card-title fw-bold text-dark">@item.Title</h5>
                                <p class="card-text text-muted text-truncate">@item.Content</p>
                                <a href="/Post/Details/@item.Id" class="btn btn-outline-danger btn-sm mt-auto align-self-start">Đọc tiếp</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="container mt-4">
        <h3 class="text-center mb-3 fw-bold text-dark">DANH MỤC SẢN PHẨM</h3>
        <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
            @{
                var categories = ViewBag.Categories as IEnumerable<CMS.Data.Entities.CategoryProduct>;
                var selectedId = ViewBag.SelectedCategoryId as int?;
            }
            <a href="/" class="btn @(selectedId == null ? "btn-danger" : "btn-dark") rounded-pill px-4">Tất cả</a>

            @if (categories != null)
            {
                foreach (var cat in categories)
                {
                    <a href="/?categoryId=@cat.Id"
                       class="btn @(selectedId == cat.Id ? "btn-danger" : "btn-outline-primary") rounded-pill px-4">
                        @cat.Name
                    </a>
                }
            }
        </div>
    </div>

    <div class="container mb-5">
        <h2 class="text-center mb-4 text-primary fw-bold">SẢN PHẨM</h2>
        <div class="row">
            @{
                var products = ViewBag.Products as IEnumerable<CMS.Data.Entities.Product>;
            }
            @if (products != null && products.Any())
            {
                foreach (var item in products)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm h-100 border-0">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/600x400?text=No+Image" : item.ImageUrl)"
                                 class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-dark">@item.Name</h5>
                                <p class="card-text text-danger fw-bold">@item.Price.ToString("N0") ₫</p>
                                <a href="/Product/Details/@item.Id" class="btn btn-primary w-100">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center"><p class="text-muted">Không tìm thấy sản phẩm trong danh mục này.</p></div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>