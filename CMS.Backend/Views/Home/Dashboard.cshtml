@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Dashboard - Tổng quan";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-speedometer2 text-primary me-2"></i> Tổng quan hệ thống BG SNEAKER
        </h2>
        <a href="#" class="btn btn-primary shadow-sm fw-bold">
            <i class="bi bi-download me-1"></i> Xuất báo cáo
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow-sm border-0 border-start border-success border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-success fw-bold text-uppercase mb-1" style="font-size: 0.85rem;">Tổng Sản Phẩm Giày</div>
                            <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalProducts Mẫu</div>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                            <i class="bi bi-box-seam fs-3 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow-sm border-0 border-start border-warning border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-warning fw-bold text-uppercase mb-1" style="font-size: 0.85rem;">Tin Tức & Bài Viết</div>
                            <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalPosts Bài</div>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                            <i class="bi bi-journal-text fs-3 text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow-sm border-0 border-start border-info border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-info fw-bold text-uppercase mb-1" style="font-size: 0.85rem;">Tổng Danh Mục</div>
                            <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalCategories Loại</div>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                            <i class="bi bi-tags fs-3 text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow-sm border-0 border-start border-primary border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-primary fw-bold text-uppercase mb-1" style="font-size: 0.85rem;">Nhân Viên & Admin</div>
                            <div class="h4 mb-0 fw-bold text-dark">@ViewBag.TotalUsers Người</div>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                            <i class="bi bi-people fs-3 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">Đơn Hàng Gần Đây</h5>
                    <a href="/Orders" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Mã ĐH</th>
                                    <th>Khách Hàng</th>
                                    <th>Ngày Đặt</th>
                                    <th>Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.RecentOrders != null)
                                {
                                    foreach (var order in ViewBag.RecentOrders)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">#ORD-@order.Id</td>
                                            <td>@(order.Customer?.FullName ?? "Khách vãng lai")</td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                @if (order.Status == 0)
                                                {
                                                    <span class="badge bg-warning text-dark px-2 py-1 rounded-pill">Chờ duyệt</span>
                                                }
                                                else if (order.Status == 1)
                                                {
                                                    <span class="badge bg-info px-2 py-1 rounded-pill">Đang giao</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success px-2 py-1 rounded-pill">Hoàn thành</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center py-4 text-muted">Chưa có đơn hàng nào trong hệ thống.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark">Cảnh Báo Tồn Kho</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.LowStockProducts != null)
                    {
                        foreach (var product in ViewBag.LowStockProducts)
                        {
                            <div class="d-flex align-items-center border-bottom pb-3 mb-3">
                                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/uploads/default-shoe.png" : product.ImageUrl)"
                                     alt="Shoe" class="rounded me-3 bg-light border" style="width: 50px; height: 50px; object-fit: cover;"
                                     onerror="this.src='https://placehold.co/50?text=No+Image'">
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold text-truncate" style="max-width: 180px;">@product.Name</h6>
                                    @if (product.StockQuantity == 0)
                                    {
                                        <small class="text-danger fw-bold"><i class="bi bi-x-circle"></i> Hết hàng</small>
                                    }
                                    else
                                    {
                                        <small class="text-warning text-dark fw-bold"><i class="bi bi-exclamation-triangle"></i> Còn @product.StockQuantity đôi</small>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">Kho hàng đang hoạt động ổn định.</div>
                    }
                    <a href="/Product/Index" class="btn btn-outline-secondary w-100 mt-2 fw-bold">Xem toàn bộ kho hàng</a>
                </div>
            </div>
        </div>
    </div>
</div>