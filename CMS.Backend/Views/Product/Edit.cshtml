@model CMS.Data.Entities.Product
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 800px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> CHỈNH SỬA SẢN PHẨM</h4>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="All" class="text-danger fw-bold mb-4 p-3 border border-danger rounded bg-light"></div>

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold text-secondary">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryProductId" class="form-label fw-bold text-secondary">Danh mục sản phẩm</label>
                    <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.Categories" required>
                        <option value="">-- Vui lòng chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryProductId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold text-secondary">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" class="form-control" required min="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="StockQuantity" class="form-label fw-bold text-secondary">Số lượng tồn kho</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" required min="0" />
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Hình ảnh sản phẩm</label>

                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Ảnh sản phẩm hiện tại:</small>
                        <img src="@Model.ImageUrl" class="img-thumbnail rounded shadow-sm" style="max-height: 120px; object-fit: cover;" alt="Current Image">
                    </div>

                    <input type="hidden" asp-for="ImageUrl" />

                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                    <small class="text-muted fs-7">Để trống nếu bạn muốn giữ nguyên ảnh cũ hiện tại.</small>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold text-secondary">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control" rows="5" required></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/Product/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-warning fw-bold px-4 shadow-sm">
                        <i class="bi bi-save"></i> Cập nhật thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}