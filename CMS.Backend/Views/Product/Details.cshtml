@model CMS.Data.Entities.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = null; // Hoặc Layout = "_LayoutAdmin"; tùy bạn muốn giữ giao diện nào
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@Model.Name - PhucCMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <a href="/" class="btn btn-secondary mb-3"><i class="bi bi-arrow-left"></i> Quay lại</a>

        <div class="card shadow-sm p-4 border-0">
            <div class="row">
                <div class="col-md-5">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/600x400" : Model.ImageUrl)"
                         class="img-fluid rounded" alt="@Model.Name">
                </div>
                <div class="col-md-7">
                    <h2 class="fw-bold text-primary">@Model.Name</h2>
                    <span class="badge bg-success mb-3">@Model.CategoryProduct?.Name</span>

                    <h4 class="text-danger fw-bold">@Model.Price.ToString("N0") ₫</h4>
                    <p class="mt-3"><strong>Tồn kho:</strong> @Model.StockQuantity</p>
                    <hr />
                    <h5>Mô tả:</h5>
                    <p class="text-muted">@Model.Description</p>

                    <button class="btn btn-primary btn-lg mt-3">Thêm vào giỏ hàng</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>