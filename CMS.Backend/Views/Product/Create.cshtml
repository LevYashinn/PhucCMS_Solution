@model CMS.Data.Entities.Product
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 800px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-box-seam"></i> THÊM SẢN PHẨM MỚI</h4>
        </div>

        <div class="card-body p-4">
            <form action="/Product/Create" method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold text-secondary">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" required placeholder="Nhập tên sản phẩm..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold text-secondary">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" class="form-control" required min="0" placeholder="Ví dụ: 500000" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="StockQuantity" class="form-label fw-bold text-secondary">Số lượng tồn kho</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" required min="0" placeholder="Ví dụ: 100" />
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Hình ảnh sản phẩm</label>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" required />
                    <small class="text-muted fs-7">Vui lòng chọn ảnh định dạng .jpg, .png, .webp...</small>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold text-secondary">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập mô tả chi tiết sản phẩm..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/Product/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-success fw-bold px-4 shadow-sm">
                        <i class="bi bi-plus-circle"></i> Thêm sản phẩm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}