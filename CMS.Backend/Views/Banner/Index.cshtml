@model IEnumerable<CMS.Data.Entities.Banners>

@{
    ViewData["Title"] = "Quản lý Banner/SlideShow";
    Layout = "_LayoutAdmin"; // Hoặc tên file Layout Admin của bạn
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Danh Sách Banner / SlideShow</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Thêm Banner Mới
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th style="width: 150px;">Hình Ảnh</th>
                            <th>Tiêu Đề</th>
                            <th>Đường Dẫn Đích (Link)</th>
                            <th style="width: 120px;" class="text-center">Thứ Tự Hiện</th>
                            <th style="width: 130px;" class="text-center">Trạng Thái</th>
                            <th style="width: 150px;" class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td class="text-center">
                                        <img src="@item.ImageUrl" alt="@item.Title" style="max-height: 60px; max-width: 130px; object-fit: cover; border-radius: 4px;" class="border shadow-sm" />
                                    </td>
                                    <td class="font-weight-bold">@item.Title</td>
                                    <td>
                                        <span class="text-muted small text-truncate d-inline-block" style="max-width: 250px;">@item.LinkUrl</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge badge-secondary px-3 py-2">@item.OrderDisplay</span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge badge-success px-2 py-1"><i class="fas fa-check-circle mr-1"></i>Đang bật</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger px-2 py-1"><i class="fas fa-times-circle mr-1"></i>Đang ẩn</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info" title="Sửa thông tin">
                                                <i class="fas fa-edit"></i> Sửa
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger" onclick="return confirm('Bạn chắc chắn muốn xóa banner này vĩnh viễn chứ?');" title="Xóa banner">
                                                <i class="fas fa-trash"></i> Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Chưa có banner nào được tạo.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>