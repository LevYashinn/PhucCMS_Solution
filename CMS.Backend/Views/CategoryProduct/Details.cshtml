@model CMS.Data.Entities.CategoryProduct
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết Danh mục";
}

<div class="container mt-4 px-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle"></i> THÔNG TIN DANH MỤC</h5>
            <div>
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning btn-sm fw-bold me-2">
                    <i class="bi bi-pencil"></i> Sửa
                </a>
                <a asp-action="Index" class="btn btn-light text-info btn-sm fw-bold">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-3 text-muted fw-bold">ID Danh mục:</div>
                <div class="col-md-9 mb-2">
                    <span class="badge bg-secondary">#@Model.Id</span>
                </div>

                <div class="col-md-3 text-muted fw-bold">Tên Danh mục:</div>
                <div class="col-md-9 mb-2 text-primary fw-bold fs-5">@Model.Name</div>

                <div class="col-md-3 text-muted fw-bold">Mô tả:</div>
                <div class="col-md-9 mb-2">@(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-box-seam"></i> SẢN PHẨM TRONG DANH MỤC
                <span class="badge bg-success ms-2">@(Model.Products?.Count ?? 0) sản phẩm</span>
            </h5>
        </div>

        <div class="card-body p-0">
            @if (Model.Products != null && Model.Products.Any())
            {
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>Hình ảnh</th>
                            <th>Tên Sản phẩm</th>
                            <th>Giá Bán</th>
                            <th>Tồn kho</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="align-middle text-center">
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td class="fw-bold">@product.Id</td>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://placehold.co/50x50" : (product.ImageUrl.StartsWith("~") ? product.ImageUrl.Substring(1) : product.ImageUrl))"
                                         alt="@product.Name" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: contain;" />
                                </td>
                                <td class="text-start fw-bold text-dark">@product.Name</td>
                                <td class="text-danger fw-bold">@product.Price.ToString("N0") đ</td>
                                <td>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success">@product.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết hàng</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Product/Details/@product.Id" class="btn btn-outline-info btn-sm">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-box-seam fs-1 d-block mb-2 text-secondary opacity-50"></i>
                    <p class="mb-0">Danh mục này hiện chưa có sản phẩm nào.</p>
                </div>
            }
        </div>
    </div>
</div>