@model IEnumerable<CMS.Data.Entities.CategoryProduct>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách Danh mục";
}

<div class="container mt-4 px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-list-ul"></i> QUẢN LÝ DANH MỤC SẢN PHẨM</h4>
            <a asp-action="Create" class="btn btn-light text-primary fw-bold btn-sm shadow-sm">
                <i class="bi bi-plus-circle"></i> Thêm danh mục mới
            </a>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Tên Danh mục</th>
                        <th>Mô tả</th>
                        <th>Số lượng Sản phẩm</th>
                        <th style="width: 280px;">Hành động</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold">@item.Id</td>
                            <td class="text-primary fw-bold">@item.Name</td>
                            <td>@item.Description</td>
                            <td class="text-center">
                                <span class="badge bg-success rounded-pill px-3 py-2">
                                    @(item.Products?.Count ?? 0)
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-dark">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                <p class="mb-0">Chưa có danh mục nào trong hệ thống.</p>
            </div>
        }
    </div>
</div>