@model IEnumerable<CMS.Data.Entities.Category>
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-bookmarks"></i> QUẢN LÝ DANH MỤC BÀI VIẾT</h2>

        <a href="/Category/Create" class="btn btn-primary fw-bold shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm danh mục mới
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0 align-middle">
                <thead class="table-primary text-center">
                    <tr>
                        <th width="10%">ID</th>
                        <th width="30%">Tên danh mục</th>
                        <th width="40%">Mô tả</th>
                        <th width="20%">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">@item.Id</td>
                                <td class="text-primary fw-bold">@item.Name</td>
                                <td class="text-muted">@(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)</td>
                                <td class="text-center">
                                    <a href="/Category/Edit/@item.Id" class="btn btn-sm btn-warning shadow-sm me-2 text-dark">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a href="/Category/Delete/@item.Id" class="btn btn-sm btn-danger shadow-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục: @item.Name?');">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                <h5>Chưa có danh mục bài viết nào.</h5>
                                <p>Hãy bấm nút <strong>"Thêm danh mục mới"</strong> ở góc trên bên phải để bắt đầu nhé!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation example">
            <ul class="pagination justify-content-end shadow-sm">

                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link fw-bold text-primary" href="/Category/Index?page=@(ViewBag.CurrentPage - 1)" tabindex="-1" aria-disabled="@(ViewBag.CurrentPage == 1 ? "true" : "false")">
                        <i class="bi bi-chevron-left"></i> Trước
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link fw-bold" href="/Category/Index?page=@i">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link fw-bold text-primary" href="/Category/Index?page=@(ViewBag.CurrentPage + 1)" aria-disabled="@(ViewBag.CurrentPage == ViewBag.TotalPages ? "true" : "false")">
                        Sau <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>