@model CMS.Data.Entities.Category
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-folder-plus"></i> THÊM DANH MỤC BÀI VIẾT MỚI</h4>
        </div>

        <div class="card-body p-4">
            <form action="/Category/Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold text-secondary">Tên danh mục bài viết</label>
                    <input asp-for="Name" class="form-control" required placeholder="Ví dụ: Tin tức giày, Mẹo phối đồ, Khuyến mãi..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold text-secondary">Mô tả danh mục</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết cho danh mục này..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/Category/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-primary fw-bold px-4 shadow-sm">
                        <i class="bi bi-plus-circle"></i> Lưu danh mục bài viết
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}