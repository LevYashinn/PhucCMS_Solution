@model CMS.Data.Entities.CategoryProduct
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-tags"></i> THÊM DANH MỤC SẢN PHẨM MỚI</h4>
        </div>

        <div class="card-body p-4">
            <form action="/CategoryProduct/Create" method="post">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold text-secondary">Tên danh mục</label>
                    <input asp-for="Name" class="form-control" required placeholder="Ví dụ: Giày Thể Thao Nam..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold text-secondary">Mô tả danh mục</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/CategoryProduct/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-success fw-bold px-4 shadow-sm">
                        <i class="bi bi-plus-circle"></i> Lưu vào hệ thống
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}