@model CMS.Data.Entities.Category
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> SỬA DANH MỤC BÀI VIẾT</h4>
            <span class="badge bg-light text-primary">ID: @Model.Id</span>
        </div>

        <div class="card-body p-4">
            <form action="/Category/Edit/@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold text-secondary">Tên danh mục bài viết</label>
                    <input asp-for="Name" class="form-control" required placeholder="Ví dụ: Tin tức giày, Khuyến mãi..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold text-secondary">Mô tả danh mục</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/Category/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Hủy thay đổi
                    </a>
                    <button type="submit" class="btn btn-warning fw-bold px-4 text-dark shadow-sm">
                        <i class="bi bi-save"></i> Cập nhật danh mục
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}