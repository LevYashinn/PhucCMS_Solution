@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 800px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> CHỈNH SỬA BÀI VIẾT</h4>
        </div>

        <div class="card-body p-4">
            <form action="/Post/Edit" method="post" enctype="multipart/form-data">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold text-secondary">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-bold text-secondary">Chuyên mục bài viết</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">-- Chọn chuyên mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Hình ảnh bài viết</label>

                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Ảnh hiện tại:</small>
                        <img src="@Model.ImageUrl" class="img-thumbnail rounded shadow-sm" style="max-height: 120px; object-fit: cover;" alt="Current Image">
                    </div>

                    <input type="hidden" asp-for="ImageUrl" />

                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                    <small class="text-muted fs-7">Để trống nếu bạn muốn giữ nguyên ảnh cũ.</small>
                </div>

                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-bold text-secondary">Nội dung chi tiết</label>
                    <textarea asp-for="Content" class="form-control" rows="6" required></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <input type="hidden" asp-for="CreatedDate" />

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/Post/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-warning fw-bold px-4 shadow-sm">
                        <i class="bi bi-save"></i> Cập nhật thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}