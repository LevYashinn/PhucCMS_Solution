@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 px-4" style="max-width: 800px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> SỬA BÀI VIẾT (TIN TỨC)</h4>
        </div>

        <div class="card-body p-4">
            <form action="/Post/Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />
                <input type="hidden" asp-for="CreatedDate" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold text-secondary">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" required placeholder="Nhập tiêu đề..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-bold text-secondary">Danh mục</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">-- Vui lòng chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="mb-4 bg-light p-3 rounded-3 border">
                    <label class="form-label fw-bold text-secondary">Đổi hình đại diện (Bỏ trống nếu muốn giữ nguyên ảnh cũ)</label>

                    <input type="file" id="imageInput" name="uploadImage" class="form-control mb-2" accept="image/*" onchange="previewImage(event)" />

                    <div class="text-center mt-3">
                        <p class="small text-muted mb-1">Ảnh hiển thị hiện tại:</p>
                        <img id="imagePreview" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/600x400?text=No+Image" : Model.ImageUrl)" alt="Xem trước ảnh" class="img-thumbnail shadow-sm" style="max-height: 250px; object-fit: contain;" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-bold text-secondary">Nội dung bài viết</label>
                    <textarea asp-for="Content" class="form-control" rows="8" placeholder="Nhập nội dung..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a href="/Post/Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-warning fw-bold px-4 shadow-sm text-dark">
                        <i class="bi bi-save"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewImage(event) {
            const input = event.target;
            const preview = document.getElementById('imagePreview');
            // Nếu khách chọn file mới, đổi lại hình hiển thị
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}